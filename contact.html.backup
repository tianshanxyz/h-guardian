<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | H-Guardian Medical Mask Manufacturer</title>
    <meta name="description" content="Contact H-Guardian for OEM mask manufacturing, factory visits, or business inquiries. Get in touch with our professional team.">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.h-guardian.com/contact.html">
    <meta property="og:title" content="Contact Us | H-Guardian Medical Mask Manufacturer">
    <meta property="og:description" content="Contact H-Guardian for OEM mask manufacturing, factory visits, or business inquiries. Get in touch with our professional team.">
    <meta property="og:image" content="https://www.h-guardian.com/images/contact/hero-bg.jpg">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://www.h-guardian.com/contact.html">
    <meta name="twitter:title" content="Contact Us | H-Guardian Medical Mask Manufacturer">
    <meta name="twitter:description" content="Contact H-Guardian for OEM mask manufacturing, factory visits, or business inquiries. Get in touch with our professional team.">
    <meta name="twitter:image" content="https://www.h-guardian.com/images/contact/hero-bg.jpg">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.h-guardian.com/contact.html">
    
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/responsive.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="images/favicon.ico">
    <style>
        /* Contact页面特有样式 */
        .page-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('images/contact/hero-bg.jpg');
            background-size: cover;
            background-position: center;
            color: white;
            text-align: center;
            padding: 120px 0 80px;
        }
        
        .page-hero h1 {
            font-size: 3rem;
            margin-bottom: 20px;
        }
        
        .page-hero p {
            font-size: 1.2rem;
            max-width: 800px;
            margin: 0 auto;
            opacity: 0.9;
        }
        
        /* 联系信息部分 */
        .contact-info-section {
            padding: 100px 0;
            background: #f8f9fa;
        }
        
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            margin-top: 60px;
        }
        
        .contact-card {
            background: white;
            border-radius: 15px;
            padding: 40px 30px;
            text-align: center;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            border-top: 4px solid var(--primary-color);
        }
        
        .contact-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.15);
        }
        
        .contact-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 2rem;
            color: white;
        }
        
        .contact-card h3 {
            color: var(--text-dark);
            margin-bottom: 20px;
            font-size: 1.5rem;
        }
        
        .contact-details {
            text-align: left;
            margin-top: 20px;
        }
        
        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .contact-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        
        .contact-item i {
            color: var(--primary-color);
            font-size: 1.2rem;
            margin-top: 3px;
            flex-shrink: 0;
        }
        
        .contact-item-content h4 {
            color: var(--text-dark);
            margin-bottom: 5px;
            font-size: 1.1rem;
        }
        
        .contact-item-content p {
            color: var(--text-light);
            line-height: 1.6;
        }
        
        .contact-item-content a {
            color: var(--primary-color);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .contact-item-content a:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }
        
        /* 地图和交通指引部分 - 优化布局 */
        .map-section {
            padding: 100px 0;
            background: white;
        }
        
        .map-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            margin-top: 50px;
            align-items: start;
        }
        
        /* 左侧：地图 + 虚拟参观 */
        .map-side {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }
        
        .map-wrapper {
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            height: 400px;
            position: relative;
        }
        
        .map-placeholder {
            width: 100%;
            height: 100%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 20px;
            text-align: center;
        }
        
        .map-placeholder i {
            font-size: 4rem;
            color: var(--primary-color);
            margin-bottom: 20px;
            opacity: 0.3;
        }
        
        .map-placeholder h3 {
            color: var(--text-dark);
            margin-bottom: 10px;
        }
        
        .map-placeholder p {
            color: var(--text-light);
            max-width: 300px;
        }
        
        /* 虚拟参观卡片 */
        .virtual-tour-card {
            background: linear-gradient(135deg, rgba(51, 153, 153, 0.05), rgba(51, 153, 153, 0.02));
            border-radius: 15px;
            padding: 30px;
            border: 1px solid rgba(51, 153, 153, 0.1);
            transition: all 0.3s ease;
        }
        
        .virtual-tour-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-color: var(--primary-light);
        }
        
        .virtual-tour-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .virtual-tour-icon {
            width: 60px;
            height: 60px;
            background: var(--primary-color);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: white;
        }
        
        .virtual-tour-header h3 {
            color: var(--text-dark);
            font-size: 1.5rem;
            margin: 0;
        }
        
        .virtual-tour-card p {
            color: var(--text-light);
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .virtual-tour-features {
            margin-bottom: 25px;
        }
        
        .virtual-tour-features li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 12px;
            color: var(--text-light);
        }
        
        .virtual-tour-features li i {
            color: var(--primary-color);
            margin-top: 2px;
            flex-shrink: 0;
        }
        
        .virtual-tour-cta {
            text-align: center;
        }
        
        /* 右侧：交通指引 */
        .transportation-guide {
            background: white;
            border-radius: 15px;
            padding: 40px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            height: 100%;
        }
        
        .transportation-guide h3 {
            color: var(--text-dark);
            margin-bottom: 30px;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .transportation-option {
            margin-bottom: 30px;
            padding-bottom: 30px;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .transportation-option:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        
        .transport-icon {
            width: 50px;
            height: 50px;
            background: #f0f9f9;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--primary-color);
            margin-bottom: 15px;
        }
        
        .transportation-option h4 {
            color: var(--text-dark);
            margin-bottom: 10px;
            font-size: 1.3rem;
        }
        
        .transportation-option p {
            color: var(--text-light);
            line-height: 1.6;
            margin-bottom: 10px;
        }
        
        .transportation-option ul {
            margin-top: 10px;
            padding-left: 20px;
        }
        
        .transportation-option li {
            color: var(--text-light);
            margin-bottom: 8px;
            position: relative;
            padding-left: 10px;
        }
        
        .transportation-option li::before {
            content: "•";
            color: var(--primary-color);
            font-weight: bold;
            position: absolute;
            left: 0;
        }
        
        /* 简单询盘表格部分 */
        .inquiry-section {
            padding: 100px 0;
            background: #f8f9fa;
        }
        
        .inquiry-form-container {
            max-width: 800px;
            margin: 50px auto 0;
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .inquiry-form-header {
            background: var(--primary-color);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .inquiry-form-header h3 {
            color: white;
            margin-bottom: 10px;
            font-size: 1.8rem;
        }
        
        .inquiry-form-header p {
            color: rgba(255,255,255,0.9);
            max-width: 600px;
            margin: 0 auto;
        }
        
        .inquiry-form {
            padding: 40px;
        }
        
        .inquiry-form .form-group {
            margin-bottom: 25px;
        }
        
        .inquiry-form label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-dark);
            font-weight: 500;
        }
        
        .inquiry-form label .required {
            color: #e74c3c;
            margin-left: 3px;
        }
        
        .inquiry-form .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }
        
        .inquiry-form .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(51, 153, 153, 0.1);
        }
        
        .inquiry-form textarea.form-control {
            min-height: 150px;
            resize: vertical;
        }
        
        .form-submit {
            text-align: center;
            margin-top: 40px;
        }
        
        .form-submit .btn {
            padding: 15px 50px;
            font-size: 1.1rem;
        }
        
        /* Q&A部分 */
        .faq-section {
            padding: 100px 0;
            background: white;
        }
        
        .faq-container {
            max-width: 900px;
            margin: 50px auto 0;
        }
        
        .faq-item {
            background: white;
            border-radius: 10px;
            margin-bottom: 20px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            transition: all 0.3s ease;
        }
        
        .faq-item:hover {
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .faq-question {
            padding: 25px 30px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #f8f9fa;
        }
        
        .faq-question h4 {
            color: var(--text-dark);
            font-size: 1.2rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .faq-question i {
            color: var(--primary-color);
            font-size: 1.2rem;
        }
        
        .faq-toggle {
            color: var(--primary-color);
            font-size: 1.2rem;
            transition: transform 0.3s ease;
        }
        
        .faq-answer {
            padding: 0 30px;
            max-height: 0;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .faq-item.active .faq-answer {
            padding: 25px 30px;
            max-height: 1000px;
        }
        
        .faq-item.active .faq-toggle {
            transform: rotate(180deg);
        }
        
        .faq-answer p {
            color: var(--text-light);
            line-height: 1.6;
            margin-bottom: 15px;
        }
        
        .faq-answer ul {
            margin-top: 10px;
            padding-left: 20px;
        }
        
        .faq-answer li {
            color: var(--text-light);
            margin-bottom: 10px;
            position: relative;
            padding-left: 10px;
        }
        
        .faq-answer li::before {
            content: "•";
            color: var(--primary-color);
            font-weight: bold;
            position: absolute;
            left: 0;
        }
        
        /* 响应式设计 */
        @media (max-width: 1200px) {
            .map-container {
                gap: 40px;
            }
        }
        
        @media (max-width: 992px) {
            .page-hero h1 {
                font-size: 2.5rem;
            }
            
            .map-container {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            
            .map-side {
                order: 2;
            }
            
            .transportation-guide {
                order: 1;
            }
            
            .map-wrapper {
                height: 350px;
            }
        }
        
        @media (max-width: 768px) {
            .page-hero {
                padding: 80px 0 60px;
            }
            
            .page-hero h1 {
                font-size: 2rem;
            }
            
            .contact-card {
                padding: 30px 20px;
            }
            
            .transportation-guide {
                padding: 30px;
            }
            
            .inquiry-form {
                padding: 30px;
            }
            
            .faq-question,
            .faq-answer {
                padding: 20px;
            }
            
            .virtual-tour-card {
                padding: 25px;
            }
        }
        
        @media (max-width: 480px) {
            .contact-icon {
                width: 70px;
                height: 70px;
                font-size: 1.8rem;
            }
            
            .map-wrapper {
                height: 250px;
            }
            
            .inquiry-form {
                padding: 20px;
            }
            
            .form-submit .btn {
                padding: 12px 30px;
                width: 100%;
            }
            
            .virtual-tour-header {
                flex-direction: column;
                text-align: center;
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="container">
            <nav class="navbar">
                <a href="index.html" class="logo">
                    <img src="images/logo.png" alt="H-Guardian Logo">
                   
                </a>
                
                <div class="nav-menu">
                    <a href="index.html" class="nav-link" data-translate="nav_home">Home</a>
                    <div class="nav-dropdown">
                        <a href="products.html" class="nav-link" data-translate="nav_products">Products <i class="fas fa-chevron-down"></i></a>
                        <div class="dropdown-content">
                            <a href="disposable-mask-for-adults.html" data-translate="product_adults">Disposable Mask for Adults</a>
                            <a href="disposable-mask-for-teens.html" data-translate="product_teens">Disposable Mask for Teens</a>
                            <a href="disposable-mask-for-kids.html" data-translate="product_kids">Disposable Mask for Kids</a>
                            <a href="double-nose-clip-mask.html" data-translate="product_double_clip">Double Nose-Clip Mask</a>
                        </div>
                    </div>
                    <a href="factory.html" class="nav-link" data-translate="nav_factory">Factory</a>
                    <a href="customization.html" class="nav-link" data-translate="nav_customization">Customization</a>
                    <a href="contact.html" class="nav-link active" data-translate="nav_contact">Contact</a>
                    
                    <div class="language-switcher">
                        <button class="language-btn">
                            <i class="fas fa-globe"></i> EN
                        </button>
                        <div class="language-dropdown">
                            <a href="#" data-lang="en">English</a>
                            <a href="#" data-lang="fr">Français</a>
                            <a href="#" data-lang="es">Español</a>
                            <a href="#" data-lang="ar">العربية</a>
                        </div>
                    </div>
                </div>
                
                <button class="mobile-menu-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </nav>
        </div>
    </header>

    <!-- Page Hero -->
    <section class="page-hero">
        <div class="container">
            <h1 data-translate="contact_hero_title">Contact Us</h1>
            <p data-translate="contact_hero_subtitle">Get in touch with our professional team for OEM manufacturing, factory visits, or business inquiries</p>
        </div>
    </section>

    <!-- 联系信息 -->
    <section class="contact-info-section">
        <div class="container">
            <div class="section-header">
                <h2 data-translate="contact_section_title">Get in Touch</h2>
                <p data-translate="contact_section_subtitle">Connect with our team through multiple channels</p>
            </div>
            
            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h3 data-translate="contact_address_title">Factory Address</h3>
                    <div class="contact-details">
                        <div class="contact-item">
                            <i class="fas fa-factory"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_factory_main">Main Manufacturing Facility</h4>
                                <p data-translate="contact_factory_address">Textile Industrial Park, Xiantao City, Hubei Province, China 433000</p>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <i class="fas fa-warehouse"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_warehouse_title">Warehouse & Logistics Center</h4>
                                <p data-translate="contact_warehouse_address">The Industrial Park NO.8 Guohe, Xiantao City, Hubei Province, China</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h3 data-translate="contact_details_title">Contact Details</h3>
                    <div class="contact-details">
                        <div class="contact-item">
                            <i class="fas fa-phone"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_phone">Phone</h4>
                                <p><a href="tel:+8617361911595">+86 173 6191 1595</a></p>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <i class="fas fa-envelope"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_email">Email</h4>
                                <p><a href="mailto:info@h-guardian.com">info@h-guardian.com</a></p>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <i class="fab fa-whatsapp"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_whatsapp">WhatsApp</h4>
                                <p><a href="https://wa.me/8617361911595">+86 173 6191 1595</a></p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h3 data-translate="contact_hours_title">Business Hours</h3>
                    <div class="contact-details">
                        <div class="contact-item">
                            <i class="fas fa-calendar-alt"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_working_days">Working Days</h4>
                                <p data-translate="contact_hours_weekday">Monday - Friday: 8:00 AM - 6:00 PM (GMT+8)</p>
                                <p data-translate="contact_hours_weekend">Saturday - Sunday: 9:00 AM - 5:00 PM (GMT+8)</p>
                            </div>
                        </div>
                        
                        <div class="contact-item">
                            <i class="fas fa-globe"></i>
                            <div class="contact-item-content">
                                <h4 data-translate="contact_timezone">Time Zone</h4>
                                <p data-translate="contact_timezone_cst">China Standard Time (GMT+8)</p>
                                <p data-translate="contact_response_time">We respond within 24 hours</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 地图和交通指引 -->
    <section class="map-section">
        <div class="container">
            <div class="section-header">
                <h2 data-translate="contact_location_title">Factory Location & Transportation</h2>
                <p data-translate="contact_location_subtitle">How to reach our manufacturing facility in Xiantao, Hubei</p>
            </div>
            
            <div class="map-container">
                <!-- 左侧：地图 + 虚拟参观 -->
                <div class="map-side">
                    <div class="map-wrapper">
                        <!-- 方案4: 静态图片 + 链接 (最稳定) -->
                        <a href="https://maps.google.com/maps?q=THE+INDUSTRIAL+PARK+NO.8,+GUOHE,+XIANTAO,+HUBEI,+CHINA&hl=en&t=m&z=15" target="_blank" style="display: block; width: 100%; height: 100%;">
                            <div class="map-placeholder">
                                <i class="fas fa-map-marked-alt"></i>
                                <h3 data-translate="map_view_google">View on Google Maps</h3>
                                <p data-translate="map_click_open">Click to open interactive map</p>
                                <p style="font-size: 0.9rem; margin-top: 10px; color: var(--primary-color);">
                                    <i class="fas fa-external-link-alt"></i> <span data-translate="map_new_window">Opens in new window</span>
                                </p>
                            </div>
                        </a>
                    </div>
                    
                    <!-- 虚拟参观卡片 -->
                    <div class="virtual-tour-card">
                        <div class="virtual-tour-header">
                            <div class="virtual-tour-icon">
                                <i class="fas fa-video"></i>
                            </div>
                            <h3 data-translate="virtual_tour_title">Virtual Factory Tour</h3>
                        </div>
                        
                        <p data-translate="virtual_tour_desc">Can't visit in person? Experience our factory through a virtual tour:</p>
                        
                        <ul class="virtual-tour-features">
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span data-translate="virtual_tour_1">Live video tour of production facilities</span>
                            </li>
                            <li>
