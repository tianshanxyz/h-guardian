                                <i class="fas fa-check-circle"></i>
                                <span data-translate="virtual_tour_4">No travel required - join from anywhere</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span data-translate="virtual_tour_5">See quality control processes in real-time</span>
                            </li>
